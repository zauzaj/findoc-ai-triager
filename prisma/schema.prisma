generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Persistent store of every clinic returned by the upstream Places API.
// lat/lng enable map pins without re-fetching coordinates.
model Clinic {
  id        String   @id         // Google place_id (stable, unique)
  name      String
  address   String
  lat       Float
  lng       Float
  phone     String?
  website   String?
  rating    Float?
  insurance String   @default("[]") // JSON-encoded String[] (SQLite has no array type)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Caches the full Place[] response for a specialist + area search.
// Cache key: "specialist:lat2dp:lng2dp" — ~1 km resolution.
// TTL: 7 days (clinics change infrequently).
model PlacesCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  results   String   // JSON-encoded Place[]
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Caches the Claude triage response for a given (symptoms, insurance) pair.
// TTL: 24 hours — deterministic but allows model updates to propagate.
model NavigateCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  result    String   // JSON-encoded NavigateResponse
  expiresAt DateTime
  createdAt DateTime @default(now())
}
