# ── Rails API ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://findoc:findoc@localhost:5432/findoc_development
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-use-rails-secret-key-base

# Anthropic (Claude) — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Places (New) API — requires Places API (New) enabled in Cloud Console
GOOGLE_PLACES_API_KEY=

# Google OAuth — Web client ID from Google Cloud Console
GOOGLE_CLIENT_ID_WEB=

# AI provider (anthropic|openai)
AI_PROVIDER=anthropic

# Optional OpenAI key (required only when AI_PROVIDER=openai)
OPENAI_API_KEY=

# Enable local mocked Google Places + AI responses
MOCK_EXTERNAL_APIS=true

# Optional mock profile from api/config/mocks/external_apis.yml
MOCK_API_PROFILE=development

# Seed mock clinic-insurance links for local testing
SEED_MOCK_DATA=true

# URL of the deployed web app (used for magic link emails + CORS)
WEB_URL=http://localhost:3000

# ── Next.js Web ───────────────────────────────────────────────────────────────
# Rails API base URL seen by the browser (no trailing slash)
NEXT_PUBLIC_RAILS_API_URL=http://localhost:3001/api/v1

# Google Maps — Static Maps + Embed (Maps Static API + Maps Embed API)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
