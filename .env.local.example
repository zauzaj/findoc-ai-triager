# Findoc UAE Frontend — Environment Variables
# Copy this file to .env.local and fill in the values

# Base URL for the backend API (no trailing slash)
# Example: https://api.findoc.ae or http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=

# Google Maps API key — enables Static Maps (multi-pin preview) and Maps Embed (per-card interactive map)
# Required APIs to enable in Google Cloud Console:
#   - Maps Static API
#   - Maps Embed API
# Directions deep links (https://www.google.com/maps/place/?q=place_id=...) do NOT require a key.
# Leave empty to hide all map UI — the rest of the app works without it.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
