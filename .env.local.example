# Findoc UAE Frontend — Environment Variables
# Copy this file to .env.local and fill in the values

# ── Database (Prisma / SQLite) ─────────────────────────────────────────────────
# SQLite file path. The prisma/ directory is gitignored for the .db file.
DATABASE_URL="file:./prisma/findoc.db"

# ── Upstream API (server-side only — NOT exposed to the browser) ───────────────
# The external backend that handles Claude triage + Google Places search.
# The Next.js /api/* routes proxy to this and cache results in SQLite.
# Example: https://api.findoc.ae or http://localhost:3001
EXTERNAL_API_URL=

# ── Override internal routing (optional) ──────────────────────────────────────
# Leave empty to use the built-in /api/* caching routes (recommended).
# Set to the same value as EXTERNAL_API_URL to bypass caching and hit upstream directly.
NEXT_PUBLIC_API_BASE_URL=

# ── Google Maps (client-side) ─────────────────────────────────────────────────
# Enables Static Maps (multi-pin overview) and Maps Embed (per-card iframe).
# Required APIs: Maps Static API, Maps Embed API.
# Directions deep links work without a key — leave empty to hide all map UI.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
